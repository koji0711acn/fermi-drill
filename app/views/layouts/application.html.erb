<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "Fermi Drill" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Fermi Drill">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="<%= root_path %>" class="text-xl font-bold text-indigo-600 tracking-tight">
          Fermi Drill
        </a>

        <%# Desktop nav %>
        <div class="hidden md:flex items-center gap-4 text-sm">
          <% if user_signed_in? %>
            <a href="<%= dashboard_path %>" class="text-gray-600 hover:text-indigo-600">Dashboard</a>
            <a href="<%= fermi_questions_path %>" class="text-gray-600 hover:text-indigo-600">問題一覧</a>
            <a href="<%= weakness_drill_path %>" class="text-gray-600 hover:text-indigo-600">苦手ドリル</a>
            <a href="<%= fermi_attempts_path %>" class="text-gray-600 hover:text-indigo-600">履歴</a>
            <span class="text-gray-400"><%= current_user.email %></span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "text-red-500 hover:text-red-700" %>
          <% else %>
            <a href="<%= new_user_session_path %>" class="text-gray-600 hover:text-indigo-600">ログイン</a>
            <a href="<%= new_user_registration_path %>" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">新規登録</a>
          <% end %>
        </div>

        <%# Mobile hamburger button %>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-indigo-600" aria-label="メニュー">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# Mobile menu %>
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
        <div class="px-4 py-3 space-y-2 text-sm">
          <% if user_signed_in? %>
            <a href="<%= dashboard_path %>" class="block py-2 text-gray-600 hover:text-indigo-600">Dashboard</a>
            <a href="<%= fermi_questions_path %>" class="block py-2 text-gray-600 hover:text-indigo-600">問題一覧</a>
            <a href="<%= weakness_drill_path %>" class="block py-2 text-gray-600 hover:text-indigo-600">苦手ドリル</a>
            <a href="<%= fermi_attempts_path %>" class="block py-2 text-gray-600 hover:text-indigo-600">履歴</a>
            <div class="border-t border-gray-100 pt-2 mt-2">
              <span class="block py-1 text-gray-400 text-xs"><%= current_user.email %></span>
              <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "block py-2 text-red-500 hover:text-red-700" %>
            </div>
          <% else %>
            <a href="<%= new_user_session_path %>" class="block py-2 text-gray-600 hover:text-indigo-600">ログイン</a>
            <a href="<%= new_user_registration_path %>" class="block py-2 text-indigo-600 font-semibold hover:text-indigo-700">新規登録</a>
          <% end %>
        </div>
      </div>
    </nav>

    <script>
      document.getElementById("mobile-menu-btn").addEventListener("click", function() {
        var menu = document.getElementById("mobile-menu");
        var open = document.getElementById("menu-icon-open");
        var close = document.getElementById("menu-icon-close");
        menu.classList.toggle("hidden");
        open.classList.toggle("hidden");
        close.classList.toggle("hidden");
      });
    </script>

    <% if notice.present? %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-5xl mx-auto px-4 py-4 md:py-8">
      <%= yield %>
    </main>
  </body>
</html>
