<h1 class="text-2xl font-bold text-gray-900 mb-6">問題一覧</h1>

<%# Filters %>
<div class="bg-white rounded-xl shadow-sm border p-4 mb-6">
  <div class="space-y-3">
    <div>
      <label class="text-xs text-gray-500 block mb-1">難易度</label>
      <div class="flex gap-2">
        <a href="<%= fermi_questions_path(category: params[:category]) %>"
           class="px-3 py-1 rounded-full text-sm whitespace-nowrap <%= params[:difficulty].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          All
        </a>
        <% FermiQuestion::DIFFICULTIES.each do |diff| %>
          <a href="<%= fermi_questions_path(difficulty: diff, category: params[:category]) %>"
             class="px-3 py-1 rounded-full text-sm whitespace-nowrap <%= params[:difficulty] == diff ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
            <%= diff %>
          </a>
        <% end %>
      </div>
    </div>
    <div>
      <label class="text-xs text-gray-500 block mb-1">カテゴリ</label>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <a href="<%= fermi_questions_path(difficulty: params[:difficulty]) %>"
           class="px-3 py-1 rounded-full text-sm whitespace-nowrap shrink-0 <%= params[:category].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          All
        </a>
        <% FermiQuestion::CATEGORIES.each do |cat| %>
          <a href="<%= fermi_questions_path(category: cat, difficulty: params[:difficulty]) %>"
             class="px-3 py-1 rounded-full text-sm whitespace-nowrap shrink-0 <%= params[:category] == cat ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
            <%= cat %>
          </a>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Question list %>
<div class="space-y-3">
  <% @questions.each do |question| %>
    <a href="<%= fermi_question_path(question) %>" class="block bg-white rounded-xl shadow-sm border p-4 hover:border-indigo-300 transition">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="font-semibold text-gray-800"><%= question.title %></h3>
          <div class="flex gap-2 mt-1">
            <span class="text-xs px-2 py-0.5 rounded-full
              <%= case question.difficulty
                  when 'Easy' then 'bg-green-100 text-green-700'
                  when 'Medium' then 'bg-yellow-100 text-yellow-700'
                  when 'Hard' then 'bg-red-100 text-red-700'
                  end %>">
              <%= question.difficulty %>
            </span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= question.category %></span>
            <% if question.estimated_minutes %>
              <span class="text-xs text-gray-400"><%= question.estimated_minutes %>分</span>
            <% end %>
          </div>
        </div>
        <span class="text-indigo-400 text-lg">&rarr;</span>
      </div>
    </a>
  <% end %>
</div>

<% if @questions.empty? %>
  <div class="text-center py-12 text-gray-400">
    <p>問題がありません。</p>
  </div>
<% end %>
