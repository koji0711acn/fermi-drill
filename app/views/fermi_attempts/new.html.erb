<div class="mb-4">
  <a href="<%= fermi_question_path(@question) %>" class="text-indigo-600 text-sm hover:underline">&larr; 問題に戻る</a>
</div>

<div class="bg-white rounded-xl shadow-sm border p-6 mb-6">
  <div class="mb-4">
    <div class="flex gap-2 mb-2">
      <span class="text-xs px-2 py-0.5 rounded-full
        <%= case @question.difficulty
            when 'Easy' then 'bg-green-100 text-green-700'
            when 'Medium' then 'bg-yellow-100 text-yellow-700'
            when 'Hard' then 'bg-red-100 text-red-700'
            end %>">
        <%= @question.difficulty %>
      </span>
      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= @question.category %></span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 mb-3"><%= @question.title %></h1>
  </div>

  <div class="bg-gray-50 rounded-lg p-4">
    <p class="text-gray-800 whitespace-pre-wrap"><%= @question.prompt_text %></p>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm border p-6">
  <h2 class="text-lg font-bold text-gray-900 mb-4">回答を入力</h2>

  <%= form_with(model: @attempt, url: fermi_question_fermi_attempts_path(@question), class: "space-y-6") do |f| %>
    <% if @attempt.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg">
        <ul class="list-disc list-inside">
          <% @attempt.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label for="fermi_attempt_estimated_value_text" class="block text-sm font-semibold text-gray-700 mb-1">
        推定値（数値 or テキスト）
      </label>
      <p class="text-xs text-gray-400 mb-2">例: 約55,000店、年間約200億本、月間300万回 など</p>
      <%= f.text_field :estimated_value_text,
        class: "w-full border border-gray-300 rounded-lg px-4 py-3 text-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500",
        placeholder: "推定値を入力してください" %>
    </div>

    <div>
      <label for="fermi_attempt_reasoning_text" class="block text-sm font-semibold text-gray-700 mb-1">
        思考プロセス <span class="text-red-500">*</span>
      </label>
      <p class="text-xs text-gray-400 mb-2">
        因数分解の構造、使った前提、各ステップの計算を書いてください。
        このアプリの価値は思考プロセスの評価にあります。
      </p>
      <%= f.text_area :reasoning_text,
        rows: 12,
        class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-mono text-sm",
        placeholder: "例:\n■ 分解の構造\n日本のコンビニ数 = 対象人口 × 1店舗あたりの商圏人口の逆数\n\n■ 前提\n- 日本の人口: 約1.2億人\n- コンビニの商圏人口: 約2,000〜2,500人/店\n\n■ 計算\n1.2億 ÷ 2,200 ≒ 約55,000店\n\n■ 検証\n- 大手3社で約5万店 → 妥当なレンジ" %>
    </div>

    <div class="pt-2">
      <%= f.submit "提出して採点する",
        class: "w-full bg-indigo-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-indigo-700 transition cursor-pointer",
        data: { disable_with: "採点中..." } %>
    </div>
  <% end %>
</div>
