<h1 class="text-2xl font-bold text-gray-900 mb-6">練習履歴</h1>

<% if @attempts.any? %>
  <div class="space-y-3">
    <% @attempts.each do |attempt| %>
      <a href="<%= fermi_attempt_path(attempt) %>" class="block bg-white rounded-xl shadow-sm border p-4 hover:border-indigo-300 transition">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-gray-800"><%= attempt.fermi_question.title %></h3>
            <div class="flex gap-2 mt-1">
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= case attempt.fermi_question.difficulty
                    when 'Easy' then 'bg-green-100 text-green-700'
                    when 'Medium' then 'bg-yellow-100 text-yellow-700'
                    when 'Hard' then 'bg-red-100 text-red-700'
                    end %>">
                <%= attempt.fermi_question.difficulty %>
              </span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= attempt.fermi_question.category %></span>
              <span class="text-xs text-gray-400"><%= attempt.created_at.strftime("%Y/%m/%d %H:%M") %></span>
            </div>
          </div>
          <div class="text-right">
            <% if attempt.evaluated? %>
              <p class="text-2xl font-bold text-indigo-600"><%= attempt.overall_score %></p>
              <p class="text-xs text-gray-400">点</p>
            <% else %>
              <span class="text-sm text-yellow-600 font-semibold bg-yellow-50 px-2 py-1 rounded">未採点</span>
            <% end %>
          </div>
        </div>
      </a>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16">
    <p class="text-gray-400 mb-4">まだ練習履歴がありません</p>
    <a href="<%= fermi_questions_path %>" class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition">
      最初の1問を解く
    </a>
  </div>
<% end %>
