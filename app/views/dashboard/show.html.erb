<h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

<%# Today's question %>
<% if @today_question %>
  <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold text-indigo-800 mb-2">今日の1問を解こう</h2>
    <p class="text-indigo-600 mb-4"><%= @today_question.title %></p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="<%= new_fermi_question_fermi_attempt_path(@today_question) %>" class="inline-block bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 transition text-center">
        解く
      </a>
      <a href="<%= weakness_drill_path %>" class="inline-block border border-indigo-600 text-indigo-600 px-6 py-2 rounded-lg hover:bg-indigo-50 transition text-center">
        苦手を集中練習
      </a>
    </div>
  </div>
<% else %>
  <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
    <p class="text-green-700 font-semibold">今日はもう練習済みです！</p>
    <div class="flex gap-3 mt-2">
      <a href="<%= fermi_questions_path %>" class="text-green-600 underline text-sm">もっと解く</a>
      <a href="<%= weakness_drill_path %>" class="text-green-600 underline text-sm">苦手を集中練習</a>
    </div>
  </div>
<% end %>

<%# Stats cards %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-xl shadow-sm border p-4 text-center">
    <p class="text-2xl md:text-3xl font-bold text-indigo-600"><%= @stats[:total_count] %></p>
    <p class="text-sm text-gray-500">累計練習回数</p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border p-4 text-center">
    <p class="text-2xl md:text-3xl font-bold text-indigo-600"><%= @stats[:average_score] || "-" %></p>
    <p class="text-sm text-gray-500">平均スコア</p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border p-4 text-center">
    <p class="text-2xl md:text-3xl font-bold text-indigo-600"><%= @stats[:recent_average_score] || "-" %></p>
    <p class="text-sm text-gray-500">直近5問平均</p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border p-4 text-center">
    <% if @stats[:weakest_area] %>
      <p class="text-xl font-bold text-red-500"><%= @stats[:weakest_area][:name] %></p>
      <p class="text-sm text-gray-400"><%= @stats[:weakest_area][:score] %>点</p>
    <% else %>
      <p class="text-xl font-bold text-gray-400">-</p>
    <% end %>
    <p class="text-sm text-gray-500">最も弱い項目</p>
  </div>
</div>

<%# Charts row %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
  <%# Score trend chart %>
  <% if @stats[:score_history] %>
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h3 class="font-bold text-gray-900 mb-3">スコア推移</h3>
      <canvas id="scoreChart" height="200"></canvas>
    </div>
  <% end %>

  <%# Skill radar chart %>
  <% if @stats[:skill_radar] %>
    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h3 class="font-bold text-gray-900 mb-3">スキルバランス</h3>
      <canvas id="radarChart" height="200"></canvas>
    </div>
  <% end %>
</div>

<%# Category breakdown %>
<% if @stats[:top_categories].any? %>
  <div class="bg-white rounded-xl shadow-sm border p-6 mb-8">
    <h3 class="font-bold text-gray-900 mb-3">カテゴリ別練習回数</h3>
    <div class="space-y-2">
      <% @stats[:top_categories].each do |category, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600"><%= category %></span>
          <span class="text-sm font-semibold text-indigo-600"><%= count %>回</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Recent history %>
<% if @stats[:recent_attempts].any? %>
  <div class="bg-white rounded-xl shadow-sm border p-6">
    <h3 class="font-bold text-gray-900 mb-3">直近の練習</h3>
    <div class="space-y-3">
      <% @stats[:recent_attempts].each do |attempt| %>
        <a href="<%= fermi_attempt_path(attempt) %>" class="block p-3 rounded-lg hover:bg-gray-50 border border-gray-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-semibold text-gray-800"><%= attempt.fermi_question.title %></p>
              <p class="text-xs text-gray-400"><%= attempt.created_at.strftime("%Y/%m/%d %H:%M") %></p>
            </div>
            <div class="text-right">
              <% if attempt.evaluated? %>
                <span class="text-lg font-bold text-indigo-600"><%= attempt.overall_score %></span>
                <span class="text-xs text-gray-400">点</span>
              <% elsif attempt.evaluating? %>
                <span class="text-sm text-indigo-600 font-semibold">採点中...</span>
              <% else %>
                <span class="text-sm text-yellow-600 font-semibold">未採点</span>
              <% end %>
            </div>
          </div>
        </a>
      <% end %>
    </div>
    <div class="mt-4 text-center">
      <a href="<%= fermi_attempts_path %>" class="text-indigo-600 text-sm hover:underline">すべての履歴を見る</a>
    </div>
  </div>
<% end %>

<% if @stats[:last_practiced_at] %>
  <p class="text-xs text-gray-400 mt-6 text-right">最終練習: <%= @stats[:last_practiced_at].strftime("%Y/%m/%d %H:%M") %></p>
<% end %>

<%# Chart.js rendering %>
<% if @stats[:score_history] || @stats[:skill_radar] %>
<script type="module">
  import Chart from "chart.js";

  <% if @stats[:score_history] %>
  (function() {
    const ctx = document.getElementById("scoreChart");
    if (!ctx) return;
    const data = <%= raw @stats[:score_history].to_json %>;
    new Chart(ctx, {
      type: "line",
      data: {
        labels: data.labels,
        datasets: [
          {
            label: "総合",
            data: data.overall,
            borderColor: "#4f46e5",
            backgroundColor: "rgba(79,70,229,0.1)",
            fill: true,
            tension: 0.3,
            borderWidth: 2,
            pointRadius: 3
          },
          {
            label: "因数分解",
            data: data.decomposition,
            borderColor: "#10b981",
            borderWidth: 1,
            pointRadius: 2,
            tension: 0.3,
            hidden: true
          },
          {
            label: "前提設定",
            data: data.assumptions,
            borderColor: "#f59e0b",
            borderWidth: 1,
            pointRadius: 2,
            tension: 0.3,
            hidden: true
          },
          {
            label: "桁感",
            data: data.numeracy,
            borderColor: "#ef4444",
            borderWidth: 1,
            pointRadius: 2,
            tension: 0.3,
            hidden: true
          },
          {
            label: "伝達力",
            data: data.communication,
            borderColor: "#8b5cf6",
            borderWidth: 1,
            pointRadius: 2,
            tension: 0.3,
            hidden: true
          }
        ]
      },
      options: {
        responsive: true,
        scales: {
          y: { min: 0, max: 100, ticks: { stepSize: 20 } }
        },
        plugins: {
          legend: { position: "bottom", labels: { boxWidth: 12, font: { size: 11 } } }
        }
      }
    });
  })();
  <% end %>

  <% if @stats[:skill_radar] %>
  (function() {
    const ctx = document.getElementById("radarChart");
    if (!ctx) return;
    const data = <%= raw @stats[:skill_radar].to_json %>;
    new Chart(ctx, {
      type: "radar",
      data: {
        labels: data.labels,
        datasets: [{
          label: "直近10問平均",
          data: data.values,
          backgroundColor: "rgba(79,70,229,0.15)",
          borderColor: "#4f46e5",
          borderWidth: 2,
          pointBackgroundColor: "#4f46e5",
          pointRadius: 4
        }]
      },
      options: {
        responsive: true,
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { stepSize: 20, display: false },
            pointLabels: { font: { size: 12 } }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  })();
  <% end %>
</script>
<% end %>
